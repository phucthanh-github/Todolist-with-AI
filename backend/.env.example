# MongoDB Connection Configuration
# For local MongoDB: mongodb://localhost:27017
# For MongoDB Atlas: mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=todolist_db

# Security & JWT Auth
# Generate a secret key: openssl rand -hex 32
SECRET_KEY=supersecretkey1234567890abcdefghijklmnopqrstuv
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Hugging Face Configuration (For Chatbot Agent)
# Get a free Hugging Face API Token: https://huggingface.co/settings/tokens
HF_TOKEN=your_hugging_face_api_token_here
HF_MODEL=Qwen/Qwen2.5-7B-Instruct

# Email Notification Configuration (SMTP)
# Using Gmail SMTP: smtp.gmail.com (port 587)
# You need to generate an App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password

# Frontend Origin for CORS
FRONTEND_URL=http://localhost:5173

# Google Sign-in Credentials
# Create OAuth credentials on: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here

